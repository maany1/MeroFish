# MeroFish Backend Environment Variables
# Copy this file to .env and fill in your values

# Server configuration
PORT=3000

# OpenAI API Key (used for LLM-based ontology and entity extraction)
OPENAI_API_KEY=your_api_key_here

# NOTE: ZEP_API_KEY is NOT used. Graph construction is fully in-memory.
# Do NOT add ZEP_API_KEY here — it has been intentionally removed.
